# /docker/callbotcompare/.env on the VPS — referenced by docker-compose.yml
#
# Neon — main branch
DATABASE_URL=postgresql://USER:PASS@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:PASS@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Public URLs — also baked into the build via NEXT_PUBLIC_SITE_URL build arg
SITE_URL=https://callbotcompare.com

# Runtime
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=3000
