# Database connection string used by Prisma at runtime.
# Local dev (Postgres in Docker on port 5433):
#   postgresql://app:app@localhost:5433/callbotcompare
# Neon (production) — use the POOLED connection string:
#   postgresql://USER:PASS@ep-XXXX.pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# Direct (non-pooled) Postgres connection used by `prisma migrate`.
# Locally: identical to DATABASE_URL.
# On Neon: the DIRECT (non-pooler) connection string.
DIRECT_URL=

# Canonical public site URL (used for OG, sitemap, JSON-LD, canonical tags).
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Lead notification mailer (Microsoft Graph, app-only auth) ----
# When all four AZURE_/MAIL_FROM vars are set, /api/leads and /api/quiz
# send an HTML notification email to MAIL_TO (defaults to MAIL_FROM).
# When unset, notifications fall through to console.log only.
#
# Azure setup (one-time):
#   1. portal.azure.com -> Entra ID -> App registrations -> New registration
#      Name "CallTreo Mailer", Single tenant
#   2. Copy Directory (tenant) ID and Application (client) ID below
#   3. Certificates & secrets -> New client secret -> copy the secret VALUE
#   4. API permissions -> Microsoft Graph -> Application permissions ->
#      Mail.Send -> Add -> click "Grant admin consent"
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MAIL_FROM=grady@calltreo.com
MAIL_TO=grady@calltreo.com

# ---- Google Analytics (GA4) ----
# Public Measurement ID. NEXT_PUBLIC_* vars are baked into the client
# bundle at BUILD time, so changing this requires a new image build —
# add it as a GitHub Actions secret + pass via build-args in deploy.yml,
# not just to the runtime VPS .env.
# When unset the GA snippet is never injected and trackEvent() no-ops
# silently in production.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
